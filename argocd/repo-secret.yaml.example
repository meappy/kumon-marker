# Argo CD Repository Secret for Private GitHub Repo
#
# To use this:
# 1. Copy this file to repo-secret.yaml
# 2. Replace YOUR_GITHUB_USERNAME with your GitHub username
# 3. Replace YOUR_GITHUB_PAT with a Personal Access Token with 'repo' scope
#    Generate at: https://github.com/settings/tokens
# 4. Apply with: kubectl apply -f argocd/repo-secret.yaml
#
# Alternatively, you can add the repo via Argo CD UI:
# 1. Access Argo CD UI at https://<node-ip>:30443
# 2. Login with admin / <password from: kubectl -n argocd get secret argocd-initial-admin-secret -o jsonpath="{.data.password}" | base64 -d>
# 3. Go to Settings > Repositories > Connect Repo
# 4. Choose HTTPS, enter repo URL and credentials

apiVersion: v1
kind: Secret
metadata:
  name: kumon-marker-repo
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  type: git
  url: https://github.com/meappy/kumon-marker.git
  username: YOUR_GITHUB_USERNAME
  password: YOUR_GITHUB_PAT
