# Kumon Marker Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# AI Backend Configuration
# =============================================================================

# Analysis mode: "ollama" (recommended), "gemini", "api" (Anthropic), or "cli"
CLAUDE_MODE=ollama

# Ollama (local LLM - no API costs)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=moondream

# Google Gemini (alternative cloud option)
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (alternative cloud option)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Google OAuth Configuration
# =============================================================================

# Required for user authentication
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Comma-separated list of allowed email addresses
ALLOWED_USERS=user1@gmail.com,user2@gmail.com

# =============================================================================
# Security
# =============================================================================

# Secret key for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-in-production

# =============================================================================
# Google Drive Integration
# =============================================================================

# Folder name in Google Drive to scan for worksheets
GDRIVE_FOLDER=From_BrotherDevice

# =============================================================================
# Job Queue (Optional - for production)
# =============================================================================

# RabbitMQ connection URL (enables background job processing)
# RABBITMQ_URL=amqp://user:password@localhost:5672/

# PostgreSQL connection URL (required if RabbitMQ is enabled)
# DATABASE_URL=postgresql://user:password@localhost:5432/kumon

# =============================================================================
# Application Settings
# =============================================================================

# Debug mode (set to false in production)
DEBUG=false

# Timezone for date display
TIMEZONE=Australia/Sydney

# Data directory (for Docker, use /app/data)
DATA_DIR=./data
